# {{ ansible_managed }}
#
# The AI stack: the application layer. It reaches the model only through the
# LiteLLM gateway in the platform layer, over the shared external network.

services:
  qdrant:
    image: {{ qdrant_image }}
    container_name: qdrant
    restart: unless-stopped
    volumes:
      - qdrant_data:/qdrant/storage
    ports:
      - "127.0.0.1:{{ qdrant_port }}:6333"

  # Pipelines hosts the Langfuse filter. It auto-downloads the filter on
  # first start and reads the Langfuse keys from its environment, so every
  # chat completion is traced with no manual UI configuration.
  pipelines:
    image: {{ pipelines_image }}
    container_name: pipelines
    restart: unless-stopped
    # No IPv6 route on the host; disable it so the filter download uses IPv4.
    sysctls:
      - net.ipv6.conf.all.disable_ipv6=1
    environment:
      PIPELINES_URLS: "{{ langfuse_filter_url }}"
      LANGFUSE_PUBLIC_KEY: "{{ langfuse_public_key }}"
      LANGFUSE_SECRET_KEY: "{{ langfuse_secret_key }}"
      LANGFUSE_HOST: "{{ langfuse_host }}"
    volumes:
      - pipelines_data:/app/pipelines

  openwebui:
    image: {{ openwebui_image }}
    container_name: openwebui
    restart: unless-stopped
    depends_on: [qdrant, pipelines]
    environment:
      WEBUI_SECRET_KEY: "{{ openwebui_secret_key }}"
      # All model traffic goes through the LiteLLM gateway (platform layer),
      # never straight to Ollama. The direct Ollama backend is disabled.
      ENABLE_OLLAMA_API: "false"
      ENABLE_OPENAI_API: "true"
      # Two OpenAI connections: LiteLLM provides the chat models; Pipelines
      # carries the Langfuse filter (a filter applies to all models).
      OPENAI_API_BASE_URLS: "http://litellm:4000/v1;http://pipelines:9099"
      OPENAI_API_KEYS: "{{ litellm_master_key }};{{ pipelines_api_key }}"
      DEFAULT_MODELS: "{{ litellm_chat_alias }}"
      # RAG: documents are stored in Qdrant; embeddings also go through
      # LiteLLM (openai engine), so the gateway is the only path to the model.
      VECTOR_DB: "qdrant"
      QDRANT_URI: "http://qdrant:6333"
      RAG_EMBEDDING_ENGINE: "openai"
      RAG_OPENAI_API_BASE_URL: "http://litellm:4000/v1"
      RAG_OPENAI_API_KEY: "{{ litellm_master_key }}"
      RAG_EMBEDDING_MODEL: "{{ litellm_embed_alias }}"
    volumes:
      - openwebui_data:/app/backend/data
    ports:
      - "{{ openwebui_port }}:8080"

volumes:
  qdrant_data:
  openwebui_data:
  pipelines_data:

networks:
  default:
    name: {{ docker_network }}
    external: true
