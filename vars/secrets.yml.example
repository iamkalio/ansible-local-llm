---
# Copy to secrets.yml, fill in real values, then encrypt:
#   ansible-vault encrypt secrets.yml

# Open WebUI session signing key — generate with: openssl rand -hex 32
openwebui_secret_key: "CHANGE_ME"

# Langfuse cloud project keys (cloud.langfuse.com → project → Settings → API Keys)
langfuse_public_key: "pk-lf-..."
langfuse_secret_key: "sk-lf-..."

# LiteLLM gateway
# Admin/root key for the gateway and the OWUI→LiteLLM connection.
# Must start with "sk-". Generate: echo "sk-$(openssl rand -hex 32)"
litellm_master_key: "sk-CHANGE_ME"
# Encrypts provider credentials stored in the database. openssl rand -hex 32
litellm_salt_key: "CHANGE_ME"
# Backing Postgres password and the admin UI password (user is litellm_ui_username).
litellm_postgres_password: "CHANGE_ME"
litellm_ui_password: "CHANGE_ME"
