---
# Copy to secrets.yml, fill in real values, then encrypt:
#   ansible-vault encrypt secrets.yml

# Open WebUI session signing key — generate with: openssl rand -hex 32
openwebui_secret_key: "CHANGE_ME"

# Langfuse cloud project keys (cloud.langfuse.com → project → Settings → API Keys)
langfuse_public_key: "pk-lf-..."
langfuse_secret_key: "sk-lf-..."
